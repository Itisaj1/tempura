{
  "headers": [
    {
      "source": "/favicon.svg",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"}]
    },
    {
      "source": "/favicon-32x32.png",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"}]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"}]
    }
  ],
  "rewrites": [{"source": "/((?!favicon\\.svg|favicon-32x32\\.png|apple-touch-icon\\.png|assets/).*)", "destination": "/index.html"}]
}
