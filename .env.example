# EmailJS — required for the contact form submission (CTA section).
# The form sends two emails per submission:
#   1. A notification to the studio (NOTIFY template)
#   2. An auto-reply confirmation to the visitor (AUTOREPLY template)
#
# Grab the values from https://dashboard.emailjs.com:
#   Service ID                -> Email Services
#   Public Key                -> Account -> General -> "Public Key"
#   Notify Template ID        -> Email Templates -> studio-notification template
#   Auto-reply Template ID    -> Email Templates -> visitor auto-reply template
#
# These are inlined into the client bundle by Vite at build time and are
# safe to expose publicly (EmailJS public keys are designed for that).
# Lock things down with EmailJS's "Allowed Origins" setting in prod.
VITE_EMAILJS_SERVICE_ID="your_emailjs_service_id"
VITE_EMAILJS_PUBLIC_KEY="your_emailjs_public_key"
VITE_EMAILJS_NOTIFY_TEMPLATE_ID="your_emailjs_notification_template_id"
VITE_EMAILJS_AUTOREPLY_TEMPLATE_ID="your_emailjs_autoreply_template_id"

# GEMINI_API_KEY: Reserved for future Gemini-powered features.
# Not currently consumed by the UI; safe to leave unset.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Reserved for future self-referential links / callbacks.
APP_URL="MY_APP_URL"
