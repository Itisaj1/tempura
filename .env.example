# EmailJS — required for the contact form submission (CTA section).
# Create an account at https://www.emailjs.com, then grab the values
# from your EmailJS dashboard:
#   Service ID  -> Email Services -> the service you connected
#   Template ID -> Email Templates -> your contact template
#   Public Key  -> Account -> General -> "Public Key"
# These are inlined into the client bundle by Vite at build time and are
# safe to expose publicly (they're meant to be used from the browser).
VITE_EMAILJS_SERVICE_ID="your_emailjs_service_id"
VITE_EMAILJS_TEMPLATE_ID="your_emailjs_template_id"
VITE_EMAILJS_PUBLIC_KEY="your_emailjs_public_key"

# GEMINI_API_KEY: Reserved for future Gemini-powered features.
# Not currently consumed by the UI; safe to leave unset.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Reserved for future self-referential links / callbacks.
APP_URL="MY_APP_URL"
